{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://almond-harness-studio.dev/schema/v1/harness.schema.json",
  "title": "Wire Harness Drawing",
  "type": "object",
  "required": ["meta", "nodes", "segments", "wires"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "partNumber": { "type": "string" },
        "rev": { "type": "string" },
        "date": { "type": "string" },
        "company": { "type": "string" },
        "drawnBy": { "type": "string" },
        "sheet": { "enum": ["ANSI B", "Letter", "A4", "A3"] }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": { "$ref": "#/definitions/id" },
          "kind": { "enum": ["connector", "terminal", "splice", "breakout"] },
          "position": { "$ref": "#/definitions/position" }
        },
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "connector" } } },
            "then": {
              "required": ["pins"],
              "properties": {
                "mpn": { "type": "string" },
                "description": { "type": "string" },
                "pins": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["id"],
                    "additionalProperties": false,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "label": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "terminal" } } },
            "then": {
              "required": ["style"],
              "properties": {
                "style": {
                  "enum": ["ring", "spade", "ferrule", "tinned", "bare", "solder-cup", "pin"]
                },
                "stud": { "type": "string" },
                "mpn": { "type": "string" },
                "description": { "type": "string" }
              }
            }
          },
          {
            "if": { "properties": { "kind": { "const": "splice" } } },
            "then": {
              "properties": {
                "method": { "enum": ["crimp", "solder", "ultrasonic"] },
                "description": { "type": "string" }
              }
            }
          }
        ]
      }
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "lengthMm"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/definitions/id" },
          "from": { "$ref": "#/definitions/id" },
          "to": { "$ref": "#/definitions/id" },
          "lengthMm": { "type": "number", "exclusiveMinimum": 0 },
          "covering": { "enum": ["none", "heatshrink", "pet-braid", "split-loom", "spiral-wrap"] }
        }
      }
    },
    "wires": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to"],
        "additionalProperties": false,
        "properties": {
          "id": { "$ref": "#/definitions/id" },
          "from": { "$ref": "#/definitions/endpoint" },
          "to": { "$ref": "#/definitions/endpoint" },
          "gauge": { "type": "string" },
          "color": { "type": "string" },
          "label": { "type": "string" },
          "route": { "type": "array", "items": { "$ref": "#/definitions/id" } },
          "notes": { "type": "string" }
        }
      }
    },
    "wireGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["wires"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "wires": { "type": "array", "minItems": 2, "items": { "$ref": "#/definitions/id" } },
          "twisted": { "type": "boolean" },
          "label": { "type": "string" }
        }
      }
    },
    "accessories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "qty"],
        "additionalProperties": false,
        "properties": {
          "mpn": { "type": "string" },
          "description": { "type": "string", "minLength": 1 },
          "qty": { "type": ["number", "string"] }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "root": { "$ref": "#/definitions/id" }
      }
    }
  },
  "definitions": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "endpoint": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+(\\.[A-Za-z0-9_+-]+)?$"
    },
    "position": {
      "type": "object",
      "required": ["x", "y"],
      "additionalProperties": false,
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    }
  }
}
